{% extends 'base.html.twig' %}

{% block title %}Deck Builder - ManaHoarder{% endblock %}

{% block body %}
<div class="ml-20 md:ml-64 pt-16 h-[calc(100vh-4rem)] flex overflow-hidden">
    <section class="w-full md:w-[60%] flex flex-col border-r border-[#2A2A2A] bg-[#050505]">
        <div class="p-6 border-b border-[#2A2A2A] space-y-4">
            <div class="relative group">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500 group-focus-within:text-[#FF8C00] transition-colors">search</span>
                <input class="w-full bg-[#121212] border border-[#2A2A2A] py-3 pl-12 pr-4 text-xs font-['Space_Grotesk'] tracking-widest uppercase focus:border-[#FF8C00] focus:ring-0 transition-all outline-none" placeholder="BUSCAR (placeholder)..." type="text" />
            </div>

            <div class="flex flex-wrap gap-4 items-center">
                <div class="flex items-center bg-[#121212] border border-[#2A2A2A] rounded p-1">
                    <span class="px-2 text-[10px] text-zinc-500 font-bold font-['Space_Grotesk'] uppercase mr-2 border-r border-[#2A2A2A]">CMC</span>
                    <div class="flex gap-1 pr-2">
                        {% for v in ['0','1','2','3','4','5+'] %}
                            <button type="button" class="w-6 h-6 flex items-center justify-center text-[10px] font-bold rounded hover:bg-zinc-800 text-zinc-400 {{ v=='1' ? 'bg-[#FF8C00] text-black' : '' }}">{{ v }}</button>
                        {% endfor %}
                    </div>
                </div>

                <select class="bg-[#121212] border border-[#2A2A2A] text-[10px] font-bold font-['Space_Grotesk'] uppercase text-zinc-400 focus:border-[#FF8C00] outline-none h-8 px-2 rounded">
                    <option>TODOS LOS TIPOS</option>
                    <option>CREATURE</option>
                    <option>SORCERY</option>
                    <option>INSTANT</option>
                </select>

                <div class="flex gap-2">
                    <button type="button" class="w-6 h-6 rounded-full border border-zinc-700 bg-white/10 flex items-center justify-center"><div class="w-3 h-3 rounded-full bg-zinc-100"></div></button>
                    <button type="button" class="w-6 h-6 rounded-full border border-[#FF8C00]/50 bg-[#FF8C00]/20 flex items-center justify-center"><div class="w-3 h-3 rounded-full bg-[#FF8C00]"></div></button>
                </div>
            </div>
        </div>

        <div class="flex-1 overflow-y-auto p-6 scroll-smooth">
            <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                {% for n in 1..12 %}
                    <div class="group relative aspect-[5/7] rounded-lg border border-[#2A2A2A] bg-[#1A1B1E] overflow-hidden hover:border-[#FF8C00] hover:scale-[1.02] transition-all cursor-pointer">
                        <div class="w-full h-full bg-gradient-to-tr from-zinc-900 via-zinc-800 to-zinc-900 grid place-items-center">
                            <div class="text-center px-3">
                                <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk']">Placeholder</div>
                                <div class="text-xs font-black uppercase tracking-tight text-zinc-200">Carta #{{ n }}</div>
                            </div>
                        </div>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-4">
                            <button type="button" class="w-full bg-[#FF8C00] text-black py-2 text-[10px] font-black uppercase tracking-widest rounded">Add to Deck</button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="hidden lg:flex w-[40%] flex-col bg-[#121212]">
        <div class="p-6 border-b border-[#2A2A2A] bg-[#1A1B1E]/50">
            <div class="flex justify-between items-start mb-6">
                <div>
                    <h2 class="text-xl font-bold font-['Space_Grotesk'] text-[#FF8C00] tracking-tight uppercase">DECK (placeholder)</h2>
                    <div class="flex gap-2 mt-1">
                        <span class="text-[10px] font-bold text-zinc-500 uppercase font-['Space_Grotesk']">Formato: TBD</span>
                        <span class="text-[10px] font-bold text-zinc-500 uppercase font-['Space_Grotesk']">•</span>
                        <span class="text-[10px] font-bold text-zinc-500 uppercase font-['Space_Grotesk']">{{ deckLists|length }} listas</span>
                    </div>
                </div>
                <div class="flex gap-2">
                    <a class="w-8 h-8 rounded border border-[#2A2A2A] flex items-center justify-center text-zinc-400 hover:text-white transition-colors" href="{{ path('deck_list_index') }}" title="Ir a mis listas">
                        <span class="material-symbols-outlined text-sm">style</span>
                    </a>
                </div>
            </div>

            <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest font-['Space_Grotesk']">Tus listas</p>
            <div class="mt-3 grid gap-2">
                {% for list in deckLists %}
                    <a class="flex items-center justify-between px-3 py-2 rounded border border-[#2A2A2A] hover:border-[#FF8C00] bg-[#121212]" href="{{ path('deck_list_show', {id: list.id}) }}">
                        <span class="text-xs font-bold uppercase tracking-tight text-zinc-200">{{ list.name }}</span>
                        <span class="text-[10px] font-bold text-[#FF8C00]">{{ list.items|length }}</span>
                    </a>
                {% else %}
                    <div class="text-zinc-500 text-xs">No tienes listas todavía.</div>
                {% endfor %}
            </div>
        </div>

        <div class="flex-1 overflow-y-auto p-6">
            <div class="text-zinc-400 text-sm">
                Panel derecho reservado para estadísticas, curva de maná, secciones, etc.
            </div>
        </div>

        <div class="p-6 bg-[#050505] border-t border-[#2A2A2A] grid grid-cols-2 gap-4">
            <button type="button" class="border border-[#2A2A2A] py-3 text-[10px] font-bold uppercase tracking-widest text-zinc-400 hover:bg-zinc-800 transition-colors">Export List</button>
            <button type="button" class="bg-[#FF8C00] py-3 text-[10px] font-bold uppercase tracking-widest text-black hover:bg-[#ff9d26] transition-colors">Validate Deck</button>
        </div>
    </section>
</div>
{% endblock %}


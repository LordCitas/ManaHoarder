{% extends 'base.html.twig' %}

{% block title %}{{ deckList.name }} - ManaHoarder{% endblock %}

{% block body %}
<main class="ml-20 md:ml-64 pt-16 h-screen overflow-y-auto">
    <div class="p-6 space-y-6">
        <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold uppercase tracking-widest font-['Space_Grotesk']">{{ deckList.name }}</h1>
                <p class="text-zinc-500 text-sm">{{ deckList.items|length }} cartas distintas · Vista: <span class="text-[#FF8C00] font-bold uppercase">{{ view }}</span></p>
            </div>

            <div class="flex flex-wrap gap-2">
                <a class="border border-[#2A2A2A] px-3 py-2 text-xs font-bold uppercase tracking-widest text-zinc-300 hover:bg-zinc-800 transition-colors" href="{{ path('deck_list_index') }}">← Mis listas</a>
                <a class="border border-[#2A2A2A] px-3 py-2 text-xs font-bold uppercase tracking-widest text-zinc-300 hover:bg-zinc-800 transition-colors" href="{{ path('deck_list_edit', {id: deckList.id}) }}">Editar</a>

                {% if view == 'grid' %}
                    <a class="border border-[#2A2A2A] px-3 py-2 text-xs font-bold uppercase tracking-widest text-zinc-300 hover:bg-zinc-800 transition-colors" href="{{ path('deck_list_show', {id: deckList.id, view: 'compact'}) }}">Vista compacta</a>
                {% else %}
                    <a class="border border-[#2A2A2A] px-3 py-2 text-xs font-bold uppercase tracking-widest text-zinc-300 hover:bg-zinc-800 transition-colors" href="{{ path('deck_list_show', {id: deckList.id, view: 'grid'}) }}">Vista imágenes</a>
                {% endif %}

                <form method="post" action="{{ path('deck_list_delete', {id: deckList.id}) }}" onsubmit="return confirm('¿Borrar esta lista?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_deck_list_' ~ deckList.id) }}">
                    <button class="border border-red-900/60 bg-red-900/20 px-3 py-2 text-xs font-bold uppercase tracking-widest text-red-200 hover:bg-red-900/35 transition-colors" type="submit">Borrar</button>
                </form>
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="border border-[#2A2A2A] bg-zinc-900/40 px-4 py-3 text-sm">
                    <span class="text-[#FF8C00] font-bold">{{ label|upper }}</span>
                    <span class="text-zinc-200">{{ message }}</span>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="grid grid-cols-1 lg:grid-cols-[360px_1fr] gap-4">
            <div class="border border-[#2A2A2A] bg-[#121212] p-5">
                <h2 class="text-[10px] font-black text-zinc-400 uppercase tracking-widest font-['Space_Grotesk'] mb-3">Añadir carta</h2>
                {{ form_start(addForm, { action: path('deck_list_add_item', {id: deckList.id}), attr: { class: 'space-y-3' } }) }}
                    <div>
                        {{ form_label(addForm.cardName, null, { label_attr: { class: 'block text-[10px] font-bold uppercase tracking-widest text-zinc-500 font-[\'Space Grotesk\'] mb-1' } }) }}
                        {{ form_widget(addForm.cardName, { attr: { class: 'w-full bg-[#121212] border border-[#2A2A2A] py-3 px-3 text-xs font-[\'Space Grotesk\'] tracking-widest uppercase focus:border-[#FF8C00] outline-none' } }) }}
                        {{ form_errors(addForm.cardName) }}
                    </div>
                    <div>
                        {{ form_label(addForm.quantity, null, { label_attr: { class: 'block text-[10px] font-bold uppercase tracking-widest text-zinc-500 font-[\'Space Grotesk\'] mb-1' } }) }}
                        {{ form_widget(addForm.quantity, { attr: { class: 'w-full bg-[#121212] border border-[#2A2A2A] py-3 px-3 text-xs font-[\'Space Grotesk\'] tracking-widest uppercase focus:border-[#FF8C00] outline-none' } }) }}
                        {{ form_errors(addForm.quantity) }}
                    </div>
                    <button class="w-full bg-[#FF8C00] text-black py-3 text-[10px] font-black uppercase tracking-widest rounded" type="submit">Añadir</button>
                {{ form_end(addForm) }}
                <p class="mt-3 text-zinc-500 text-xs">Placeholder: más adelante autocompletado + imágenes oficiales.</p>
            </div>

            <div class="border border-[#2A2A2A] bg-[#121212] p-5">
                <h2 class="text-[10px] font-black text-zinc-400 uppercase tracking-widest font-['Space_Grotesk'] mb-3">Cartas</h2>

                {% if deckList.items is empty %}
                    <p class="text-zinc-500 text-sm">Aún no hay cartas en esta lista.</p>
                {% else %}
                    {% if view == 'grid' %}
                        <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4">
                            {% for item in deckList.items %}
                                {% set card = item.card %}
                                <div class="group relative aspect-[5/7] rounded-lg border border-[#2A2A2A] bg-[#1A1B1E] overflow-hidden hover:border-[#FF8C00] hover:scale-[1.01] transition-all">
                                    {% if card.imageUrl %}
                                        <img class="w-full h-full object-cover" src="{{ card.imageUrl }}" alt="{{ card.name }}" />
                                    {% else %}
                                        <div class="w-full h-full grid place-items-center px-3 text-center bg-gradient-to-tr from-zinc-900 via-zinc-800 to-zinc-900">
                                            <div>
                                                <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-400 font-['Space_Grotesk']">Imagen pendiente</div>
                                                <div class="text-xs font-black uppercase tracking-tight text-zinc-200">{{ card.name }}</div>
                                            </div>
                                        </div>
                                    {% endif %}

                                    <div class="absolute top-2 right-2 flex gap-1">
                                        <div class="w-6 h-6 rounded-full bg-black/60 border border-zinc-700 flex items-center justify-center text-[10px] text-white font-bold">{{ item.quantity }}</div>
                                    </div>

                                    <div class="absolute inset-x-0 bottom-0 p-3 bg-gradient-to-t from-black/85 via-black/20 to-transparent">
                                        <div class="text-[11px] font-bold uppercase tracking-tight text-zinc-200">{{ card.name }}</div>
                                        <div class="mt-2 flex items-center justify-between">
                                            <span class="text-[10px] font-bold uppercase tracking-widest text-[#FF8C00]">{{ item.quantity }}x</span>
                                            <form method="post" action="{{ path('deck_list_delete_item', {id: deckList.id, itemId: item.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_deck_list_item_' ~ item.id) }}">
                                                <button class="text-[10px] font-bold uppercase tracking-widest text-red-300 hover:text-red-200" type="submit">Eliminar</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="grid gap-2">
                            {% for item in deckList.items %}
                                <div class="flex items-center gap-3 p-2 border border-[#2A2A2A] hover:border-zinc-700 rounded transition-all">
                                    <span class="text-xs font-bold text-[#FF8C00] w-6 text-right">{{ item.quantity }}</span>
                                    <div class="flex-1">
                                        <p class="text-xs font-bold uppercase tracking-tight text-zinc-200">{{ item.card.name }}</p>
                                    </div>
                                    <form method="post" action="{{ path('deck_list_delete_item', {id: deckList.id, itemId: item.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_deck_list_item_' ~ item.id) }}">
                                        <button class="text-[10px] font-bold uppercase tracking-widest text-red-300 hover:text-red-200" type="submit">Eliminar</button>
                                    </form>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>
</main>
{% endblock %}
